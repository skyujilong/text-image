# ============================================================
# novel2media 环境变量配置示例
# 复制本文件为 .env.local 并填入真实值
# ============================================================

# ---- 火山引擎 ARK LLM 配置 ----
# ARK API 密钥，在火山引擎控制台创建
# https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ARK_API_KEY=your-ark-api-key-here

# 使用的模型 ID（默认 doubao-seed-2.0-lite）
ARK_MODEL=doubao-seed-2.0-lite

# ARK 接口地址（通常无需修改）
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# ---- ComfyUI 服务配置 ----
# ComfyUI 服务地址（可选，默认 http://127.0.0.1:8188）
# COMFYUI_BASE_URL=http://127.0.0.1:8188

# ---- TTS 服务配置（dots.tts 批量合成）----
# dots.tts 服务地址（可选，默认 http://127.0.0.1:8080）
# TTS_BASE_URL=http://127.0.0.1:8080
